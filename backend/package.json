{
  "name": "mindshelf",
  "version": "2.3.0",
  "description": "MindShelf — AI-powered Chrome tab manager with MCP support",
  "type": "module",
  "bin": {
    "mindshelf": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx watch src/cli.ts serve",
