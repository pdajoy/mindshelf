# AI Provider: "openai" | "claude" | "ollama"
AI_PROVIDER=openai

# OpenAI (also supports compatible APIs like NVIDIA NIM, Azure OpenAI, etc.)
OPENAI_API_KEY=sk-xxx
OPENAI_BASE_URL=              # Leave empty for default OpenAI; set for compatible APIs
OPENAI_MODEL=gpt-4o-mini

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-xxx
CLAUDE_MODEL=claude-sonnet-4-20250514

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Server
PORT=3456
HOST=127.0.0.1

# Logging — outputs every AI call to backend console + keeps recent entries in memory for the frontend log viewer
LOG_API_CALLS=true
LOG_MAX_ENTRIES=500
