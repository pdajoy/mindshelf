PORT=3456

# AI Provider (openai | anthropic | ollama)
AI_PROVIDER=openai

# OpenAI (also supports compatible APIs)
OPENAI_API_KEY=sk-xxx
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini

# Anthropic
ANTHROPIC_API_KEY=sk-ant-xxx
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Obsidian — 二选一
# 方式 1: 文件直写（推荐，无需 Obsidian 运行）
OBSIDIAN_VAULT_PATH=
# 方式 2: REST API（需安装 Obsidian Local REST API 插件）
OBSIDIAN_API_URL=http://127.0.0.1:27123
OBSIDIAN_API_KEY=

# Logging
LOG_API_CALLS=true
LOG_MAX_ENTRIES=500
