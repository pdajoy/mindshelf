PORT=3456

# AI Provider (openai | anthropic)
AI_PROVIDER=openai

# OpenAI (also works with any OpenAI-compatible API: Ollama, vLLM, Azure, etc.)
OPENAI_API_KEY=sk-xxx
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini

# For Ollama: set OPENAI_BASE_URL=http://localhost:11434/v1 and OPENAI_API_KEY=ollama
# For Azure: set OPENAI_BASE_URL=https://your-resource.openai.azure.com/openai/deployments/your-deployment

# Anthropic
ANTHROPIC_API_KEY=sk-ant-xxx
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Obsidian export — pick one
# Option 1: Direct file write (recommended, no Obsidian running needed)
OBSIDIAN_VAULT_PATH=
# Option 2: REST API (requires Obsidian Local REST API plugin)
OBSIDIAN_API_URL=http://127.0.0.1:27123
OBSIDIAN_API_KEY=

# Logging
LOG_API_CALLS=true
LOG_MAX_ENTRIES=500
